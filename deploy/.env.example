# ─── Sentinel SIEM/XDR — Environment Configuration ────────────────────
# Copy this file to .env and customize for your deployment.
# All values below are auto-generated by the install script in production.

# ── Ports ─────────────────────────────────────────────────────────────
GRPC_PORT=4222
REST_PORT=8443
DASHBOARD_PORT=3000

# ── OpenSearch ────────────────────────────────────────────────────────
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=Sentinel_P@ss_2025

# ── JWT ───────────────────────────────────────────────────────────────
# IMPORTANT: Generate a strong random secret for production!
# openssl rand -base64 64
JWT_SECRET=change-me-in-production

# ── TLS ───────────────────────────────────────────────────────────────
# The server auto-generates its CA on first boot.
# No manual certificate configuration required.
